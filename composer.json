{
    "name": "arseno25/hosting-laravel-deploy",
    "description": "Universal deployment tool for Laravel to any shared hosting or VPS via SSH with GitHub Actions support",
    "keywords": [
        "laravel",
        "deployment",
        "ssh",
        "hosting",
        "vps",
        "github-actions",
        "cicd",
        "automated-deployment"
    ],
    "homepage": "https://github.com/arseno25/laravel-hosting-deploy",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/arseno25/laravel-hosting-deploy/issues",
        "source": "https://github.com/arseno25/laravel-hosting-deploy",
        "docs": "https://github.com/arseno25/laravel-hosting-deploy/blob/main/README.md",
        "security": "https://github.com/arseno25/laravel-hosting-deploy/blob/main/SECURITY.md"
    },
    "authors": [
        {
            "name": "Arseno25",
            "email": "arseno25@example.com",
            "role": "Developer",
            "homepage": "https://github.com/Arseno25"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/process": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^2.0|^3.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Arseno25\\HostingLaravelDeploy\\": "src/",
            "Arseno25\\HostingLaravelDeploy\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arseno25\\HostingLaravelDeploy\\Tests\\": "tests/",
            "Arseno25\\HostingLaravelDeploy\\Database\\Factories\\": "database/factories/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "analyze": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arseno25\\HostingLaravelDeploy\\HostingDeployServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
